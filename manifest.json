{
  "manifest_version": 3,
  "name": "公益站收藏",
  "version": "0.99.0.3",
  "version_name": "1.0.0-rc.3",
  "description": "一键收藏公益/中转站：就地加 Key、复制调用、查看余额、导入导出",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html"
}
